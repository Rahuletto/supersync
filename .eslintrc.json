{
  "plugins": ["obsidian"],
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-console": ["warn", {"allow": ["error", "warn"]}]
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "node": true
  }
}
